# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# Risk Management
RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
DAILY_RESET_HOUR=9
INITIAL_PAPER_BALANCE=100000.0

# Default Broker: "upstox" or "delta"
DEFAULT_BROKER=upstox

# Upstox Environment: "sandbox" (paper API) or "live" (real orders)
UPSTOX_ENV=sandbox

# Upstox — LIVE credentials (from https://upstox.com/developer/api-documentation)
UPSTOX_LIVE_API_KEY=
UPSTOX_LIVE_API_SECRET=
UPSTOX_LIVE_ACCESS_TOKEN=

# Upstox — SANDBOX credentials (separate key/token from Upstox developer portal)
UPSTOX_SANDBOX_API_KEY=
UPSTOX_SANDBOX_API_SECRET=
UPSTOX_SANDBOX_ACCESS_TOKEN=

# Upstox — optional dedicated token for market data / analytics API
# (get_ohlc, LTP, balance use this token; order placement uses the token above)
# If blank, the active environment's access token is reused for data calls.
UPSTOX_DATA_ACCESS_TOKEN=

# Delta Exchange API (Crypto Derivatives)
DELTA_API_KEY=
DELTA_API_SECRET=
DELTA_BASE_URL=https://api.india.delta.exchange
